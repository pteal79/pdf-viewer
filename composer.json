{
    "name": "pteal/plugin-pdf-viewer",
    "description": "PDF document viewer with pinch-to-zoom, popup screen panel with close and native share functionality for iOS and Android",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter Teal",
            "email": "peter.teal79@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pteal\\PdfViewer\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pteal\\PdfViewer\\PdfViewerServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
